@page
@model AnalyticsModel

<h2>Inventory Analytics</h2>

<canvas id="stockChart"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>

<script>
    // Use pre-serialized JSON from backend
    const dataFromServer = @Html.Raw(Model.StockDataJson);

    const datasets = [];

    for (const stockId in dataFromServer) {
        const points = dataFromServer[stockId];

        datasets.push({
            label: stockId,
            data: points.map(p => ({
                x: p.date,
                y: Number(p.amount)
            })),
            borderWidth: 2,
            fill: false
        });
       
        console.log(points.map(p => p.date || p.Date));
        console.log(new Date(points[0].date || points[0].Date));
    }
    
    const maxY = Math.max(...datasets.flatMap(ds => ds.data.map(d => d.y)));

    const ctx = document.getElementById('stockChart').getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: { datasets },
        options: {
            parsing: false,
            scales: {
                x: {
                    type: 'time',
                    time: { unit: 'day' }
                },
                y: {
                    beginAtZero: true,
                    suggestedMax: maxY * 1.1
                }
            }
        }
    });
</script>