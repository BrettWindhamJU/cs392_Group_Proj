@page
@model AnalyticsModel
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.7.1/nouislider.min.css" />
</head>
<h2>Inventory Analytics</h2>

<canvas id="stockChart"></canvas>

<div style="margin-top: 25px;">
    <div id="dateSlider"></div>

    <div style="display:flex; justify-content:space-between; margin-top:8px;">
        <small id="startLabel"></small>
        <small id="endLabel"></small>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.7.1/nouislider.min.js"></script>

<script>
    const dataFromServer = @Html.Raw(Model.StockDataJson);

    let chart;

    // Flatten timestamps
    const allDates = Object.values(dataFromServer)
        .flatMap(s => s.data)
        .map(p => p.date)
        .sort((a, b) => a - b);

    const minTime = allDates[0];
    const maxTime = allDates[allDates.length - 1];

    const startLabel = document.getElementById("startLabel");
    const endLabel = document.getElementById("endLabel");

    function formatDate(ms) {
        return new Date(ms).toLocaleDateString();
    }

    function buildChart(startTime, endTime) {
        const datasets = [];

        for (const stockId in dataFromServer) {
            const stock = dataFromServer[stockId];

            const filtered = stock.data.filter(p =>
                p.date >= startTime && p.date <= endTime
            );

               datasets.push({
                label: stock.name,
                data: filtered.map(p => ({
                    x: p.date,
                    y: Number(p.amount)
                })),
                borderWidth: 2,
                fill: false,

                // smoothing
                tension: 0.3,
                cubicInterpolationMode: 'monotone',
            });
        }

        const ctx = document.getElementById("stockChart").getContext("2d");

        if (chart) chart.destroy();

        chart = new Chart(ctx, {
            type: "line",
            data: { datasets },
            options: {
                parsing: false,
                   scales: {
                    x: {
                        type: "time",
                        time: {
                            unit: "day",
                            tooltipFormat: "PP"
                        }
                    },
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // INIT NOUISLIDER
    const slider = document.getElementById("dateSlider");

    noUiSlider.create(slider, {
        start: [minTime, maxTime],
        connect: true,
        range: {
            min: minTime,
            max: maxTime
        },
        step: 1 // allow full smooth range (milliseconds)
    });

    slider.noUiSlider.on("update", function (values) {
        const startTime = Number(values[0]);
        const endTime = Number(values[1]);

        startLabel.textContent = "From: " + formatDate(startTime);
        endLabel.textContent = "To: " + formatDate(endTime);

        buildChart(startTime, endTime);
    });

    // initial render
    const initial = slider.noUiSlider.get();
    buildChart(Number(initial[0]), Number(initial[1]));
</script>