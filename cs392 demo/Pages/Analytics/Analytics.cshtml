@page
@model AnalyticsModel

<h2>Inventory Analytics</h2>

<canvas id="stockChart"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>

<script>
    // Serialize C# dictionary to JS object
    const dataFromServer = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StockData));

    const datasets = [];

    for (const stockId in dataFromServer) {
        const points = dataFromServer[stockId];

        datasets.push({
            label: stockId,
            data: points.map(p => ({
                x: new Date(p.date),
                y: Number(p.amount)  // Force numeric type
            })),
            borderWidth: 2,
            fill: false
        });
    }

    const ctx = document.getElementById('stockChart').getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: { datasets },
        options: {
            parsing: false,
            scales: {
                x: {
                    type: 'time',
                    time: { unit: 'day' }
                },
                y: {
                    beginAtZero: true,
                    optional: auto-scale max
                    suggestedMax: Math.max(...datasets.flatMap(ds => ds.data.map(d => d.y))) * 1.1
                }
            }
        }
    });
</script>