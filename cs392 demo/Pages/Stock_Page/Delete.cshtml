@page
@model cs392_demo.Pages.Stock_Page.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<section class="delete-shell">
    <header class="delete-header">
        <h1>Delete Stock Item</h1>
        <p class="inventory-subtitle">This action permanently removes this stock record.</p>
    </header>

    <div class="delete-card">
        <p class="delete-warning">Are you sure you want to delete this item?</p>
        <div asp-validation-summary="All" class="text-danger"></div>

        <dl class="delete-grid">
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Location_Stock_ID)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Location_Stock_ID)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Item_Name)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Item_Name)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.SKU)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.SKU)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Amount)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Amount)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Danger_Range)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Danger_Range)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Last_Updated)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Last_Updated)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Last_Updated_by)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Last_Updated_by)
            </dd>
        </dl>

        <form method="post" class="delete-actions">
            <input type="hidden" asp-for="Stock.Stock_ID" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
        </form>
    </div>
</section>
