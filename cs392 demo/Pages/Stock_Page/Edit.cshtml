@page
@model cs392_demo.Pages.Stock_Page.EditModel

@{
    ViewData["Title"] = "Edit";
}

<section class="edit-shell">
    <header class="edit-header">
        <h1>Edit Stock</h1>
        <p class="inventory-subtitle">Update stock values and save your changes.</p>
    </header>

    <div class="edit-card">
        <form method="post" class="edit-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Stock.Stock_ID" />
            <div class="form-group">
                <label asp-for="Stock.Location_Stock_ID" class="control-label"></label>
                <input asp-for="Stock.Location_Stock_ID" class="form-control" />
                <span asp-validation-for="Stock.Location_Stock_ID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.Item_Name" class="control-label"></label>
                <input asp-for="Stock.Item_Name" class="form-control" />
                <span asp-validation-for="Stock.Item_Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.SKU" class="control-label"></label>
                <input asp-for="Stock.SKU" class="form-control" />
                <span asp-validation-for="Stock.SKU" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.Amount" class="control-label"></label>
                <input asp-for="Stock.Amount" class="form-control" />
                <span asp-validation-for="Stock.Amount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.Danger_Range" class="control-label"></label>
                <input asp-for="Stock.Danger_Range" class="form-control" />
                <span asp-validation-for="Stock.Danger_Range" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.Last_Updated" class="control-label"></label>
                <input class="form-control" value="@(Model.Stock.Last_Updated?.ToString("g") ?? string.Empty)" readonly />
                <input type="hidden" asp-for="Stock.Last_Updated" />
                <span asp-validation-for="Stock.Last_Updated" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stock.Last_Updated_by" class="control-label"></label>
                <input class="form-control" value="@(User?.Identity?.Name ?? "System")" readonly />
                <input type="hidden" asp-for="Stock.Last_Updated_by" />
                <span asp-validation-for="Stock.Last_Updated_by" class="text-danger"></span>
            </div>
            <div class="edit-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
