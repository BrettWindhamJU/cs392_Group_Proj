@page
@model cs392_demo.Pages.Stock_Page.IndexModel

@{
    ViewData["Title"] = "Stock";
    var canManageStock = User.IsInRole("Owner") || User.IsInRole("Manager");
}

<h1>Stock</h1>

@if (canManageStock)
{
    <p>
        <a asp-page="Create">Add New Inventory Item</a>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Location_Stock_ID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Item_Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].SKU)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Amount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Danger_Range)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Last_Updated)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock[0].Last_Updated_by)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Stock) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Location_Stock_ID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Item_Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SKU)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Amount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Danger_Range)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Last_Updated)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Last_Updated_by)
            </td>
            <td>
                @if (canManageStock)
                {
                    <a asp-page="./Edit" asp-route-id="@item.Stock_ID">Edit</a>
                    <span> | </span>
                }
                <a asp-page="./Details" asp-route-id="@item.Stock_ID">Details</a>
                @if (canManageStock)
                {
                    <span> | </span>
                    <a asp-page="./Delete" asp-route-id="@item.Stock_ID">Delete</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
