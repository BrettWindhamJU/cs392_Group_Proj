@page
@model cs392_demo.Pages.Stock_Page.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<section class="details-shell">
    <header class="details-header">
        <h1>Stock Details</h1>
    </header>

    <div class="details-card">
        <dl class="details-grid">
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Location_Stock_ID)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Location_Stock_ID)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Item_Name)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Item_Name)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.SKU)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.SKU)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Amount)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Amount)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Danger_Range)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Danger_Range)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Last_Updated)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Last_Updated)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Stock.Last_Updated_by)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Stock.Last_Updated_by)
            </dd>
        </dl>

        <div class="details-actions">
            @if (User.IsInRole("Owner") || User.IsInRole("Manager"))
            {
                <a asp-page="./Edit" asp-route-id="@Model.Stock.Stock_ID">Edit</a>
            }
            <a asp-page="./Index">Back to List</a>
        </div>
    </div>
</section>
