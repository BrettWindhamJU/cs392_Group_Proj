@page
@model IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

@if (User.Identity?.IsAuthenticated ?? false)
{
    <p>Track inventory status, recent updates and important alerts.</p>
    <p>Use the navigation bar to access inventory tools.</p>
}
else
{
    <p>Please sign in to access inventory tools.</p>
}
