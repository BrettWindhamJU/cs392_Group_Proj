@page
@model cs392_demo.Pages.Users_Page.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<section class="details-shell">
    <header class="details-header">
        <h1>User Details</h1>
    </header>

    <div class="details-card">
        <dl class="details-grid">
            <dt>
            @Html.DisplayNameFor(model => model.Users.UserName)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.UserName)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Users.Email)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.Email)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Users.Role_Database)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.Role_Database)
            </dd>
        </dl>

        <div class="details-actions">
            <a asp-page="./Edit" asp-route-id="@Model.Users.Id">Edit</a>
            <a asp-page="./Index">Back to List</a>
        </div>
    </div>
</section>
