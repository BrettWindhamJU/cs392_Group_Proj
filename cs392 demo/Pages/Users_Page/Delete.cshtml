@page
@model cs392_demo.Pages.Users_Page.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<section class="delete-shell">
    <header class="delete-header">
        <h1>Delete User</h1>
        <p class="inventory-subtitle">This action permanently removes this user record.</p>
    </header>

    <div class="delete-card">
        <p class="delete-warning">Are you sure you want to delete this user?</p>

        <dl class="delete-grid">
            <dt>
            @Html.DisplayNameFor(model => model.Users.UserName)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.UserName)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Users.Email)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.Email)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Users.Role_Database)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Users.Role_Database)
            </dd>
        </dl>

        <form method="post" class="delete-actions">
            <input type="hidden" asp-for="Users.Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
        </form>
    </div>
</section>
