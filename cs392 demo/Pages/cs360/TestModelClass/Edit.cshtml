@page
@model cs392_demo.Pages.EditModel

@{
    ViewData["Title"] = "Edit";
}

<section class="edit-shell">
    <header class="edit-header">
        <h1>Edit Test Model Entry</h1>
        <p class="inventory-subtitle">Update the value and save your changes.</p>
    </header>

    <div class="edit-card">
        <form method="post" class="edit-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TestModelClass.testVal" class="control-label"></label>
                <input asp-for="TestModelClass.testVal" class="form-control" />
                <span asp-validation-for="TestModelClass.testVal" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="TestModelClass.testKey" />
            <div class="edit-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
