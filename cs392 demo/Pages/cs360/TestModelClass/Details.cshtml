@page
@model cs392_demo.Pages.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<section class="details-shell">
    <header class="details-header">
        <h1>TestModel Details</h1>
    </header>

    <div class="details-card">
        <dl class="details-grid">
            <dt>
            @Html.DisplayNameFor(model => model.TestModelClass.testVal)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.TestModelClass.testVal)
            </dd>
        </dl>

        <div class="details-actions">
            <a asp-page="./Edit" asp-route-id="@Model.TestModelClass.testKey">Edit</a>
            <a asp-page="./Index">Back to List</a>
        </div>
    </div>
</section>
