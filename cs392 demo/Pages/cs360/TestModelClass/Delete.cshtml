@page
@model cs392_demo.Pages.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<section class="delete-shell">
    <header class="delete-header">
        <h1>Delete Test Model Entry</h1>
        <p class="inventory-subtitle">This action permanently removes this record.</p>
    </header>

    <div class="delete-card">
        <p class="delete-warning">Are you sure you want to delete this entry?</p>

        <dl class="delete-grid">
            <dt>
            @Html.DisplayNameFor(model => model.TestModelClass.testVal)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.TestModelClass.testVal)
            </dd>
        </dl>

        <form method="post" class="delete-actions">
            <input type="hidden" asp-for="TestModelClass.testKey" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
        </form>
    </div>
</section>
