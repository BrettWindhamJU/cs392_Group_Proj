@page
@model cs392_demo.Pages.cs360.Inventory_Location.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<section class="delete-shell">
    <header class="delete-header">
        <h1>Delete Inventory Location</h1>
        <p class="inventory-subtitle">This action permanently removes this location record.</p>
    </header>

    <div class="delete-card">
        <p class="delete-warning">Are you sure you want to delete this location?</p>

        <dl class="delete-grid">
            <dt>
            @Html.DisplayNameFor(model => model.Inventory_Location.Location_name)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Inventory_Location.Location_name)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Inventory_Location.Address_Location)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Inventory_Location.Address_Location)
            </dd>
        </dl>

        <form method="post" class="delete-actions">
            <input type="hidden" asp-for="Inventory_Location.location_id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-page="/cs360/Inventory_Location/Index">Back to List</a>
        </form>
    </div>
</section>
