@page
@model cs392_demo.Pages.cs360.Inventory_Location.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<section class="details-shell">
    <header class="details-header">
        <h1>Inventory Location Details</h1>
    </header>

    <div class="details-card">
        <dl class="details-grid">
            <dt>Location ID</dt>
            <dd>@Model.Inventory_Location.location_id</dd>
            <dt>
            @Html.DisplayNameFor(model => model.Inventory_Location.Location_name)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Inventory_Location.Location_name)
            </dd>
            <dt>
            @Html.DisplayNameFor(model => model.Inventory_Location.Address_Location)
            </dt>
            <dd>
            @Html.DisplayFor(model => model.Inventory_Location.Address_Location)
            </dd>
        </dl>

        <div class="details-actions">
            <a asp-page="./Edit" asp-route-id="@Model.Inventory_Location.location_id">Edit</a>
            <a asp-page="/cs360/Inventory_Location/Index">Back to List</a>
        </div>
    </div>
</section>
