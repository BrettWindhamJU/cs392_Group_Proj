@page
@model cs392_demo.Pages.cs360.Inventory_Location.IndexModel

@{
    ViewData["Title"] = "Inventory Locations";
}

<h1>Inventory Locations</h1>

<p>
    <a asp-page="Create">Add New Location</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Location ID</th>
            <th>Location Name</th>
            <th>Address</th>
            <th>Owner User ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Inventory_Location)
{
        <tr>
            <td>@item.location_id</td>
            <td>@item.Location_name</td>
            <td>@item.Address_Location</td>
            <td>@item.Owner_User_ID</td>
            <td>
                <a asp-page="Edit" asp-route-id="@item.location_id">Edit</a> |
                <a asp-page="Details" asp-route-id="@item.location_id">Details</a> |
                <a asp-page="Delete" asp-route-id="@item.location_id">Delete</a> |
                <a asp-page="/Stock_Page/Create" asp-route-Location_Id="@item.location_id">Add Stock</a>
            </td>
        </tr>
}
    </tbody>
</table>
