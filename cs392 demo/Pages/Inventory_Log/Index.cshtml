@page
@model cs392_demo.Pages.Inventory_Log.IndexModel

@{
    ViewData["Title"] = "Inventory Log";
    var totalLogs = Model.AllLogsCount;
    var decreasedChanges = Model.DecreasedLogsCount;
    var increasedChanges = Model.IncreasedLogsCount;
    var activeStatus = string.IsNullOrWhiteSpace(Model.Status) ? "all" : Model.Status;
    var isAllActive = string.Equals(activeStatus, "all", StringComparison.OrdinalIgnoreCase);
    var isDecreasedActive = string.Equals(activeStatus, "decreased", StringComparison.OrdinalIgnoreCase);
    var isIncreasedActive = string.Equals(activeStatus, "increased", StringComparison.OrdinalIgnoreCase);
    var canPage = Model.TotalPages > 1;
    var pageStart = Model.PageStartItem;
    var pageEnd = Model.PageEndItem;
    var pageWindowStart = Math.Max(1, Model.PageNumber - 1);
    var pageWindowEnd = Math.Min(Model.TotalPages, pageWindowStart + 2);
    pageWindowStart = Math.Max(1, pageWindowEnd - 2);
}

<section class="inventory-list-shell">
    <div class="inventory-list-header">
        <div class="inventory-table-heading">
            <div>
                <h1>Inventory Log</h1>
                <p class="inventory-subtitle">Total @totalLogs log entr@(totalLogs == 1 ? "y" : "ies")</p>
                <a class="inventory-header-link" asp-page="Create">Create New</a>
            </div>
        </div>

        <div class="stock-controls-bar stock-controls-under-header">
            <div class="inventory-status-chips stock-controls-chips">
                <a class="inventory-chip stock-chip-icon log-chip-all @(isAllActive ? "stock-chip-active" : string.Empty)" asp-page="./Index" asp-route-status="all" asp-route-pageNumber="1">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="7" x2="16" y2="7"></line><line x1="8" y1="12" x2="16" y2="12"></line><line x1="8" y1="17" x2="16" y2="17"></line></svg>
                    <span>All Logs (@totalLogs)</span>
                </a>
                <a class="inventory-chip stock-chip-icon log-chip-increase @(isIncreasedActive ? "stock-chip-active" : string.Empty)" asp-page="./Index" asp-route-status="increased" asp-route-pageNumber="1">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="19" x2="12" y2="6"></line><polyline points="7 11 12 6 17 11"></polyline></svg>
                    <span>Increased (@increasedChanges)</span>
                </a>
                <a class="inventory-chip stock-chip-icon log-chip-decrease @(isDecreasedActive ? "stock-chip-active" : string.Empty)" asp-page="./Index" asp-route-status="decreased" asp-route-pageNumber="1">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="18"></line><polyline points="7 13 12 18 17 13"></polyline></svg>
                    <span>Decreased (@decreasedChanges)</span>
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Inventory_Activity_Log.Any())
    {
        <div class="inventory-empty-state logs-empty-state">
            <h2>No log entries found</h2>
            <p>Once inventory changes are recorded, they will appear here with quantities, timestamps, and audit details.</p>
        </div>
    }
    else
    {
        <div class="inventory-table-only-card">
            <table class="table inventory-table">
                <thead>
                    <tr>
                        <th>Log ID</th>
                        <th>Stock ID</th>
                        <th>Quantity Before</th>
                        <th>Quantity After</th>
                        <th>Changed By</th>
                        <th>Changed At</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Inventory_Activity_Log)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Log_ID)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Stock_ID_Log)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Quantity_Before)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Quantity_After)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Changed_By)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Changed_At)
                            </td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@item.Log_ID">Edit</a> |
                                <a asp-page="./Details" asp-route-id="@item.Log_ID">Details</a> |
                                <a asp-page="./Delete" asp-route-id="@item.Log_ID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="inventory-pagination-shell" aria-label="Inventory log pagination">
            <div class="inventory-pagination-meta">
                Showing @pageStart-@pageEnd of @Model.FilteredLogsCount
            </div>
            <div class="inventory-pagination-controls">
                @if (canPage)
                {
                    <a class="inventory-page-btn" asp-page="./Index" asp-route-status="@activeStatus" asp-route-pageNumber="1" aria-label="First page">&laquo;</a>
                    <a class="inventory-page-btn" asp-page="./Index" asp-route-status="@activeStatus" asp-route-pageNumber="@(Model.PageNumber - 1)" aria-label="Previous page">&lsaquo;</a>
                }
                else
                {
                    <span class="inventory-page-btn is-disabled" aria-hidden="true">&laquo;</span>
                    <span class="inventory-page-btn is-disabled" aria-hidden="true">&lsaquo;</span>
                }

                @for (var pageIndex = pageWindowStart; pageIndex <= pageWindowEnd; pageIndex++)
                {
                    if (pageIndex == Model.PageNumber)
                    {
                        <span class="inventory-page-btn is-current" aria-current="page">@pageIndex</span>
                    }
                    else
                    {
                        <a class="inventory-page-btn" asp-page="./Index" asp-route-status="@activeStatus" asp-route-pageNumber="@pageIndex">@pageIndex</a>
                    }
                }

                @if (canPage)
                {
                    <a class="inventory-page-btn" asp-page="./Index" asp-route-status="@activeStatus" asp-route-pageNumber="@(Model.PageNumber + 1)" aria-label="Next page">&rsaquo;</a>
                    <a class="inventory-page-btn" asp-page="./Index" asp-route-status="@activeStatus" asp-route-pageNumber="@Model.TotalPages" aria-label="Last page">&raquo;</a>
                }
                else
                {
                    <span class="inventory-page-btn is-disabled" aria-hidden="true">&rsaquo;</span>
                    <span class="inventory-page-btn is-disabled" aria-hidden="true">&raquo;</span>
                }
            </div>
        </div>
    }
</section>
