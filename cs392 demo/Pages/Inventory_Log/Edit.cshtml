@page
@model cs392_demo.Pages.Inventory_Log.EditModel

@{
    ViewData["Title"] = "Edit";
}

<section class="edit-shell">
    <header class="edit-header">
        <h1>Edit Inventory Log</h1>
        <p class="inventory-subtitle">Update this log entry and save your changes.</p>
    </header>

    <div class="edit-card">
        <form method="post" class="edit-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Log_ID" class="control-label"></label>
                <input asp-for="Inventory_Activity_Log.Log_ID" class="form-control" readonly />
                <span asp-validation-for="Inventory_Activity_Log.Log_ID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Stock_ID_Log" class="control-label"></label>
                <input class="form-control" value="@Model.Inventory_Activity_Log.Stock_ID_Log" readonly />
                <input type="hidden" asp-for="Inventory_Activity_Log.Stock_ID_Log" />
                <span asp-validation-for="Inventory_Activity_Log.Stock_ID_Log" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Quantity_Before" class="control-label"></label>
                <input asp-for="Inventory_Activity_Log.Quantity_Before" class="form-control" />
                <span asp-validation-for="Inventory_Activity_Log.Quantity_Before" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Quantity_After" class="control-label"></label>
                <input asp-for="Inventory_Activity_Log.Quantity_After" class="form-control" />
                <span asp-validation-for="Inventory_Activity_Log.Quantity_After" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Changed_By" class="control-label"></label>
                <input class="form-control" value="@(User?.Identity?.Name ?? "System")" readonly />
                <input type="hidden" asp-for="Inventory_Activity_Log.Changed_By" />
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Activity_Log.Changed_At" class="control-label"></label>
                <input class="form-control" value="@(Model.Inventory_Activity_Log.Changed_At.ToString("g"))" readonly />
                <input type="hidden" asp-for="Inventory_Activity_Log.Changed_At" />
            </div>
            <div class="edit-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-page="./Index">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
