@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<Users> UserManager
@inject cs392_demo.Data.cs392_demoContext DbContext
@{
    string? businessName = null;
    if (User.Identity?.IsAuthenticated ?? false)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (!string.IsNullOrWhiteSpace(currentUser?.BusinessId))
        {
            businessName = await DbContext.Business
                .Where(b => b.Business_ID == currentUser.BusinessId)
                .Select(b => b.Business_Name)
                .FirstOrDefaultAsync();
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cs392_demo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cs392_demo.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="min-vh-100 d-flex flex-column">
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container">
                    <div class="navbar-brand-wrap">
                        <a class="navbar-brand" href="/Index">StockWise</a>
                        @if (!string.IsNullOrWhiteSpace(businessName))
                        {
                            <span class="navbar-business-context" title="Current business">
                                <span class="navbar-business-name">@businessName</span>
                            </span>
                        }
                    </div>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            if (User.IsInRole("Owner"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/Index">Owner Dashboard</a>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" style="color:#c39a4b"
                                       href="#" role="button" data-bs-toggle="dropdown">Owner Tools
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" asp-page="/cs360/Inventory_Location/Index">Inventory Locations</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Inventory_Log/Index">Inventory Logs</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Stock_Page/Index">Stock</a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Invitations/Index">Team Access</a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            else if (User.IsInRole("Manager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/Index">Manager Dashboard</a>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" style="color:#c39a4b"
                                       href="#" role="button" data-bs-toggle="dropdown">Manager Tools
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" asp-page="/cs360/Inventory_Location/Index">Inventory Locations</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Inventory_Log/Index">Inventory Logs</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Stock_Page/Index">Stock</a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Stock_Page/Index">Inventory</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Suppliers">Suppliers</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Orders">Orders</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/Reports">Reports</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark nav-link-with-icon" href="/Index">
                                    <span class="nav-link-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
                                            <rect x="13" y="3" width="8" height="5" rx="1.5"></rect>
                                            <rect x="13" y="10" width="8" height="11" rx="1.5"></rect>
                                            <rect x="3" y="13" width="8" height="8" rx="1.5"></rect>
                                        </svg>
                                    </span>
                                    <span>Dashboard</span>
                                </a>
                            </li>
                        }
                    </ul>

                        <partial name="_LoginPartial" />

                    </div>
                </div>
            </nav>
        </header>

        <div class="container flex-grow-1">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted mt-auto">
            <div class="container">
                &copy; 2026 - StockWise -
                <a asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>