@page
@model cs392_demo.Pages.cs360.Inventory_Location.CreateModel

@{
    ViewData["Title"] = "Add Inventory Location";
}

<section class="edit-shell">
    <header class="edit-header">
        <h1>Add Inventory Location</h1>
        <p class="inventory-subtitle">Set up a new location to keep stock organized.</p>
    </header>

    <div class="edit-card">
        <form method="post" class="edit-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Inventory_Location.location_id" class="control-label"></label>
                <input asp-for="Inventory_Location.location_id" class="form-control" />
                <span asp-validation-for="Inventory_Location.location_id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Location.Location_name" class="control-label"></label>
                <input asp-for="Inventory_Location.Location_name" class="form-control" />
                <span asp-validation-for="Inventory_Location.Location_name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory_Location.Address_Location" class="control-label"></label>
                <input asp-for="Inventory_Location.Address_Location" class="form-control" />
                <span asp-validation-for="Inventory_Location.Address_Location" class="text-danger"></span>
            </div>
            <div class="edit-actions">
                <button type="submit" class="btn btn-primary">Save Location</button>
                <a class="btn btn-outline-secondary" asp-page="/Inventory_Location/Index">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
